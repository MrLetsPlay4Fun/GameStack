# ── GameStack Konfiguration ───────────────────────────────────────────────────
# Kopiere diese Datei zu .env und passe die Werte an.

# Sicherer JWT-Schlüssel (mindestens 32 zufällige Zeichen)
# Generieren mit: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# URL unter der das Frontend erreichbar ist (für CORS)
# Beispiel: http://192.168.1.100 oder https://gamestack.meinedomain.de
FRONTEND_URL=http://localhost

# HTTP-Port auf dem GameStack erreichbar ist (Standard: 80)
HTTP_PORT=80

# Pfade für Server-Daten und Backups (absolut oder relativ)
SERVERS_PATH=./data/servers
BACKUPS_PATH=./data/backups
