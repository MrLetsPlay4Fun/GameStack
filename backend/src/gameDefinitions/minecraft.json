{
  "id": "minecraft",
  "name": "Minecraft",
  "emoji": "⛏️",
  "description": "Java Edition Minecraft Server (Paper)",
  "type": "java",
  "defaultPort": 25565,
  "features": {
    "whitelist": {
      "supported": true,
      "file": "whitelist.json",
      "format": "json",
      "enableCommand": "whitelist on",
      "disableCommand": "whitelist off",
      "reloadCommand": "whitelist reload",
      "note": "Spieler werden per UUID + Name eingetragen"
    },
    "banlist": {
      "supported": true,
      "file": "banned-players.json",
      "format": "json",
      "note": "Gesperrte Spieler mit Grund und Ablaufdatum"
    },
    "console": true,
    "rcon": false
  },
  "defaultConfig": {
    "minecraftVersion": "1.21.4",
    "maxPlayers": 20,
    "gamemode": "survival",
    "difficulty": "normal",
    "memory": "2048"
  },
  "configFields": [
    { "key": "minecraftVersion", "label": "Minecraft-Version", "type": "text", "default": "1.21.4" },
    { "key": "maxPlayers", "label": "Max. Spieler", "type": "number", "default": 20 },
    { "key": "gamemode", "label": "Spielmodus", "type": "select", "options": ["survival", "creative", "adventure"], "default": "survival" },
    { "key": "difficulty", "label": "Schwierigkeit", "type": "select", "options": ["peaceful", "easy", "normal", "hard"], "default": "normal" },
    { "key": "memory", "label": "RAM (MB)", "type": "number", "default": 2048 }
  ]
}
