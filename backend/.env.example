# GameStack Backend – Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an.
# Diese Datei (.env.example) darf in Git eingecheckt werden.
# Die .env Datei mit echten Werten NIEMALS einchecken!

# Server-Port
PORT=3001

# Frontend-URL (für CORS) – bei lokaler Entwicklung:
FRONTEND_URL=http://localhost:5173

# JWT Secret – ZWINGEND ÄNDERN!
# Generieren mit: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# Datenbank (SQLite – wird automatisch angelegt)
DATABASE_URL="file:./gamestack.db"
